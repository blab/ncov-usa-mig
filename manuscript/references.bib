  author = {Matteson, Nathaniel L. and Hassler, Gabriel W. and Kurzban, Ezra and Schwab, Madison A. and Perkins, Sarah A. and Gangavarapu, Karthik and Levy, Joshua I. and Parker, Edyth and Pride, David and Hakim, Abbas and De Hoff, Peter and Cheung, Willi and {Castro-Martinez}, Anelizze and Rivera, Andrea and Veder, Anthony and Rivera, Ariana and Wauer, Cassandra and Holmes, Jacqueline and Wilson, Jedediah and Ngo, Shayla N. and Plascencia, Ashley and Lawrence, Elijah S. and Smoot, Elizabeth W. and Eisner, Emily R. and Tsai, Rebecca and Chac{\'o}n, Marisol and Baer, Nathan A. and Seaver, Phoebe and Salido, Rodolfo A. and Aigner, Stefan and Ngo, Toan T. and Barber, Tom and Ostrander, Tyler and {Fielding-Miller}, Rebecca and Simmons, Elizabeth H. and Zazueta, Oscar E. and {Serafin-Higuera}, Idanya and {Sanchez-Alavez}, Manuel and {Moreno-Camacho}, Jose L. and {Garc{\'i}a-Gil}, Abraham and Murphy Schafer, Ashleigh R. and McDonald, Eric and Corrigan, Jeremy and Malone, John D. and Stous, Sarah and Shah, Seema and Moshiri, Niema and Weiss, Alana and Anderson, Catelyn and Aceves, Christine M. and Spencer, Emily G. and Hufbauer, Emory C. and Lee, Justin J. and King, Alison J. and Ramesh, Karthik S. and Nguyen, Kelly N. and Saucedo, Kieran and {Robles-Sikisaka}, Refugio and Fisch, Kathleen M. and Gonias, Steven L. and Birmingham, Amanda and McDonald, Daniel and Karthikeyan, Smruthi and Martin, Natasha K. and Schooley, Robert T. and Negrete, Agustin J. and Reyna, Horacio J. and Chavez, Jose R. and Garcia, Maria L. and {Cornejo-Bravo}, Jose M. and Becker, David and Isaksson, Magnus and Washington, Nicole L. and Lee, William and Garfein, Richard S. and {Luna-Ruiz Esparza}, Marco A. and {Alc{\'a}ntar-Fern{\'a}ndez}, Jonathan and Henson, Benjamin and Jepsen, Kristen and {Olivares-Flores}, Beatriz and {Barrera-Badillo}, Gisela and {Lopez-Mart{\'i}nez}, Irma and {Ram{\'i}rez-Gonz{\'a}lez}, Jos{\'e} E. and {Flores-Le{\'o}n}, Rita and Kingsmore, Stephen F. and Sanders, Alison and Pradenas, Allorah and White, Benjamin and Matthews, Gary and Hale, Matt and McLawhon, Ronald W. and Reed, Sharon L. and Winbush, Terri and McHardy, Ian H. and Fielding, Russel A. and Nicholson, Laura and Quigley, Michael M. and Harding, Aaron and Mendoza, Art and Bakhtar, Omid and Browne, Sara H. and Olivas Flores, Jocelyn and Rincon Rodr{\'i}guez, Diana G. and Gonzalez Ibarra, Martin and Robles Ibarra, Luis C. and Arellano Vera, Betsy J. and Gonzalez Garcia, Jonathan and {Harvey-Vera}, Alicia and Knight, Rob and Laurent, Louise C. and Yeo, Gene W. and Wertheim, Joel O. and Ji, Xiang and Worobey, Michael and Suchard, Marc A. and Andersen, Kristian G. and {Campos-Romero}, Abraham and Wohl, Shirlee and Zeller, Mark},
  year = 2023,
  month = dec,
  journal = {Cell},
  volume = {186},
  number = {26},
  pages = {5690-5704.e20},
  issn = {0092-8674},
  doi = {10.1016/j.cell.2023.11.024},
  urldate = {2024-11-06},
  abstract = {The maturation of genomic surveillance in the past decade has enabled tracking of the emergence and spread of epidemics at an unprecedented level. During the COVID-19 pandemic, for example, genomic data revealed that local epidemics varied considerably in the frequency of severe acute respiratory syndrome coronavirus 2 (SARS-CoV-2) lineage importation and persistence, likely due to a combination of COVID-19 restrictions and changing connectivity. Here, we show that local COVID-19 epidemics are driven by regional transmission, including across international boundaries, but can become increasingly connected to distant locations following the relaxation of public health interventions. By integrating genomic, mobility, and epidemiological data, we find abundant transmission occurring between both adjacent and distant locations, supported by dynamic mobility patterns. We find that changing connectivity significantly influences local COVID-19 incidence. Our findings demonstrate a complex meaning of ``local'' when investigating connected epidemics and emphasize the importance of collaborative interventions for pandemic prevention and mitigation.},
  keywords = {COVID-19,genomic epidemiology,mobility,phylogenetics,SARS-CoV-2,travel restrictions,viral sequencing},
  file = {/Users/abemania/Zotero/storage/BI3SYCKY/Matteson et al. - 2023 - Genomic surveillance reveals dynamic shifts in the connectivity of COVID-19 epidemics.pdf;/Users/abemania/Zotero/storage/CDFV2T4R/Matteson et al. - 2023 - Genomic surveillance reveals dynamic shifts in the connectivity of COVID-19 epidemics.pdf;/Users/abemania/Zotero/storage/PXVR28SA/Matteson et al. - 2023 - Genomic surveillance reveals dynamic shifts in the connectivity of COVID-19 epidemics.pdf;/Users/abemania/Zotero/storage/2CFY29FT/S0092867423012783.html;/Users/abemania/Zotero/storage/EYG3GN55/S0092867423012783.html;/Users/abemania/Zotero/storage/YUY7ULPY/S0092867423012783.html}
}

@article{monodAgeGroupsThat2021,
  title = {Age Groups That Sustain Resurging {{COVID-19}} Epidemics in the {{United States}}},
  author = {Monod, M{\'e}lodie and Blenkinsop, Alexandra and Xi, Xiaoyue and Hebert, Daniel and Bershan, Sivan and Tietze, Simon and Baguelin, Marc and Bradley, Valerie C. and Chen, Yu and Coupland, Helen and Filippi, Sarah and {Ish-Horowicz}, Jonathan and McManus, Martin and Mellan, Thomas and Gandy, Axel and Hutchinson, Michael and Unwin, H. Juliette T. and {van Elsland}, Sabine L. and Vollmer, Michaela A. C. and Weber, Sebastian and Zhu, Harrison and Bezancon, Anne and Ferguson, Neil M. and Mishra, Swapnil and Flaxman, Seth and Bhatt, Samir and Ratmann, Oliver and {on behalf of the Imperial College COVID-19 Response Team}},
  year = 2021,
  month = mar,
  journal = {Science},
  volume = {371},
  number = {6536},
  pages = {eabe8372},
  publisher = {American Association for the Advancement of Science},
  doi = {10.1126/science.abe8372},
  urldate = {2026-02-23},
  abstract = {After initial declines, in mid-2020 a resurgence in transmission of novel coronavirus disease (COVID-19) occurred in the United States and Europe. As efforts to control COVID-19 disease are reintensified, understanding the age demographics driving transmission and how these affect the loosening of interventions is crucial. We analyze aggregated, age-specific mobility trends from more than 10 million individuals in the United States and link these mechanistically to age-specific COVID-19 mortality data. We estimate that as of October 2020, individuals aged 20 to 49 are the only age groups sustaining resurgent SARS-CoV-2 transmission with reproduction numbers well above one and that at least 65 of 100 COVID-19 infections originate from individuals aged 20 to 49 in the United States. Targeting interventions---including transmission-blocking vaccines---to adults aged 20 to 49 is an important consideration in halting resurgent epidemics and preventing COVID-19--attributable deaths.},
  file = {/Users/abemania/Zotero/storage/6UUIEDBJ/Monod et al. - 2021 - Age groups that sustain resurging COVID-19 epidemics in the United States.pdf}
}

@article{nanduriDimensionalityReductionDistills2024,
  title = {Dimensionality Reduction Distills Complex Evolutionary Relationships in Seasonal Influenza and {{SARS-CoV-2}}},
  author = {Nanduri, Sravani and Black, Allison and Bedford, Trevor and Huddleston, John},
  year = 2024,
  month = oct,
  journal = {Virus Evolution},
  volume = {10},
  number = {1},
  pages = {veae087},
  issn = {2057-1577},
  doi = {10.1093/ve/veae087},
  urldate = {2026-02-11},
  abstract = {Public health researchers and practitioners commonly infer phylogenies from viral genome sequences to understand transmission dynamics and identify clusters of genetically-related samples. However, viruses that reassort or recombine violate phylogenetic assumptions and require more sophisticated methods. Even when phylogenies are appropriate, they can be unnecessary or difficult to interpret without specialty knowledge. For example, pairwise distances between sequences can be enough to identify clusters of related samples or assign new samples to existing phylogenetic clusters. In this work, we tested whether dimensionality reduction methods could capture known genetic groups within two human pathogenic viruses that cause substantial human morbidity and mortality and frequently reassort or recombine, respectively: seasonal influenza A/H3N2 and SARS-CoV-2. We applied principal component analysis, multidimensional scaling (MDS), t-distributed stochastic neighbor embedding (t-SNE), and uniform manifold approximation and projection to sequences with well-defined phylogenetic clades and either reassortment (H3N2) or recombination (SARS-CoV-2). For each low-dimensional embedding of sequences, we calculated the correlation between pairwise genetic and Euclidean distances in the embedding and applied a hierarchical clustering method to identify clusters in the embedding. We measured the accuracy of clusters compared to previously defined phylogenetic clades, reassortment clusters, or recombinant lineages. We found that MDS embeddings accurately represented pairwise genetic distances including the intermediate placement of recombinant SARS-CoV-2 lineages between parental lineages. Clusters from t-SNE embeddings accurately recapitulated known phylogenetic clades, H3N2 reassortment groups, and SARS-CoV-2 recombinant lineages. We show that simple statistical methods without a biological model can accurately represent known genetic relationships for relevant human pathogenic viruses. Our open source implementation of these methods for analysis of viral genome sequences can be easily applied when phylogenetic methods are either unnecessary or inappropriate.},
  file = {/Users/abemania/Zotero/storage/2PGNQWQR/Nanduri et al. - 2024 - Dimensionality reduction distills complex evolutionary relationships in seasonal influenza and SARS-.pdf}
}

