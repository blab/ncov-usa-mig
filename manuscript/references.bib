@article{starkLocalVariationsSpatial2012,
  title = {Local {{Variations}} in {{Spatial Synchrony}} of {{Influenza Epidemics}}},
  author = {Stark, James H. and Cummings, Derek A. T. and Ermentrout, Bard and Ostroff, Stephen and Sharma, Ravi and Stebbins, Samuel and Burke, Donald S. and Wisniewski, Stephen R.},
